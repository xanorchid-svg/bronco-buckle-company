{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "broncobucklecompany.com" }],
      "destination": "https://www.broncobuckles.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.broncobucklecompany.com" }],
      "destination": "https://www.broncobuckles.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
